[Unit]
Description=Electric Racing CAN Bus Processor
After=network.target

[Service]
Type=simple
User=root
Group=root

WorkingDirectory=/home/racing/sensors-microcontrollers-25-26/onboard-rpi/racingDisplay

# '-' prefix means failure here is non-fatal (interface may not exist yet at boot)
ExecStartPre=-/bin/rm -f /dev/shm/mem123
ExecStartPre=-/home/racing/sensors-microcontrollers-25-26/onboard-rpi/racingDisplay/scripts/setup_can.sh can0 250000
ExecStartPre=-/home/racing/sensors-microcontrollers-25-26/onboard-rpi/racingDisplay/scripts/setup_can.sh can1 250000

ExecStart=/home/racing/sensors-microcontrollers-25-26/onboard-rpi/racingDisplay/venv/bin/python3 \
    /home/racing/sensors-microcontrollers-25-26/onboard-rpi/racingDisplay/core/can_processor.py

Environment=PYTHONPATH=/home/racing/sensors-microcontrollers-25-26/onboard-rpi/racingDisplay/core:/home/racing/sensors-microcontrollers-25-26/onboard-rpi/racingDisplay/config

UMask=000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=racing-can

[Install]
WantedBy=multi-user.target